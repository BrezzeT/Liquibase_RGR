<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Таблиця Користувачі -->
    <changeSet id="1" author="Brezze">
        <createTable tableName="users">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- Таблиця Категорії товарів -->
    <changeSet id="2" author="Brezze">
        <createTable tableName="categories">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Таблиця Товари зі зв'язком на Категорію -->
    <changeSet id="3" author="Brezze">
        <createTable tableName="products">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(10,2)"/>
            <column name="category_id" type="INT"/>
        </createTable>
        
        <!-- Додаємо зовнішній ключ -->
        <addForeignKeyConstraint baseTableName="products" baseColumnNames="category_id" 
                                 constraintName="fk_product_category" 
                                 referencedTableName="categories" referencedColumnNames="id"/>
    </changeSet>
        <changeSet id="4" author="Brezze">
        <addColumn tableName="products">
            <column name="description" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>


</databaseChangeLog>
